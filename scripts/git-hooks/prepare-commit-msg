#!/bin/sh
# Removes automated co-author trailers before a commit is finalized.
# Install: ./scripts/setup-git-hooks.sh

MSG_FILE="$1"
[ -f "$MSG_FILE" ] || exit 0

if sed --version >/dev/null 2>&1; then
  sed -i '/Co-authored-by: Cursor/d; /cursoragent@cursor\.com/d; /Made-with: Cursor/d' "$MSG_FILE"
else
  sed -i '' '/Co-authored-by: Cursor/d; /cursoragent@cursor\.com/d; /Made-with: Cursor/d' "$MSG_FILE"
fi

exit 0
